# Django
SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (оставьте пустыми DB_* для использования SQLite в dev/тестах)
DB_NAME=skillpath_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Neo4j (граф навыков)
GRAPH_BACKEND=memory
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Redis (кэш и channel layer для WebSocket)
REDIS_HOST=localhost
REDIS_PORT=6379
USE_REDIS_CACHE=True

# Anthropic Claude API (разбор текстового описания навыков пользователя)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
# MCP-серверы для дополнения контекста LLM (через client.beta.messages mcp_servers), список URL через запятую
MCP_SERVER_URLS=

# Внешние интеграции (используются моки, если ключи не заданы)
USE_MOCK_EXTERNAL_APIS=True
GITHUB_TOKEN=
YOUTUBE_API_KEY=
STEPIK_TOKEN=
COURSERA_TOKEN=

# Логирование (DEBUG, INFO, WARNING, ERROR)
DJANGO_LOG_LEVEL=INFO

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Суперпользователь для `python manage.py create_superuser` (создание без интерактивного ввода, для CI/деплоя)
SUPERUSER_USERNAME=
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
